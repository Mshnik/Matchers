# proto-file: com/redpup/matchers/benchmark/benchmark.proto
# proto-message: MatcherBenchmarks
# =============================================================================
# 1. VALUEMATCHER SCENARIOS (Direct Primitive Equality Checks)
# =============================================================================

benchmark {
  name: "vm_bool"
  matcher {
    message_matcher {
      message_name: "com.redpup.matchers.testing.proto.TestMessage"
      fields {
        field_name: "bool_value"
        matcher {
          value_matcher {
            bool_value: true }
        }
      }
    }
  }
  input { bool_value: true }         # Best: Instant Match
  input { bool_value: true }         # Avg: (Same for primitives)
  input { bool_value: false }        # Worst: Evaluation Mismatch
}

benchmark {
  name: "vm_int32"
  matcher {
    message_matcher {
      message_name: "com.redpup.matchers.testing.proto.TestMessage"
      fields {
        field_name: "int32_value"
        matcher {
          value_matcher {
            int32_value: 42 }
        }
      }
    }
  }
  input { int32_value: 42 }
  input { int32_value: 42 }
  input { int32_value: 0 }
}

benchmark {
  name: "vm_int64"
  matcher {
    message_matcher {
